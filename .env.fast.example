# Local fast profile for Ollama qwen2.5:3b
# Usage:
#   cp .env.fast.example .env
#   ollama pull qwen2.5:3b
#   ollama serve

# Runtime
ENVIRONMENT=dev
LOG_LEVEL=INFO
LOG_JSON=false

# Paths
DATA_DIR=data
CORPUS_DIR=docs
INDEX_DIR=data/indexes
PROMPT_DIR=prompts

# LLM (Ollama OpenAI-compatible endpoint)
LLM_PROVIDER=openai_compatible
LLM_API_BASE=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:3b
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=768
LLM_TIMEOUT_SECONDS=120
LLM_GATE_MAX_TOKENS=128
LLM_REWRITE_MAX_TOKENS=256
LLM_CRITIQUE_MAX_TOKENS=384

# Fast latency profile
RAG_DYNAMIC_BUDGET_ENABLED=true
GROUNDING_POLICY=adaptive
GROUNDING_SEMANTIC_STANDARD_ENABLED=false
GROUNDING_SEMANTIC_ADVANCED_ENABLED=true
RERANK_CASCADE_ENABLED=true
RERANK_SIMPLE_SKIP_CROSS_ENCODER=true
ADVANCED_ADAPTIVE_ENABLED=true
COMPARE_PARALLEL_ENABLED=false

# Keep advanced bounded for local hardware
MAX_ADVANCED_LOOPS=1
MEMORY_WINDOW=3

# Reranker defaults (cascade may skip cross-encoder when safe)
RERANKER_PROVIDER=cross_encoder
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu
RERANKER_BATCH_SIZE=8
RERANKER_TOP_N=6

# Embedding defaults
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16
EMBEDDING_NORMALIZE=true
