OLLAMA_BASE_URL=http://172.25.80.1:11434

# Runtime
ENVIRONMENT=dev
LOG_LEVEL=INFO
LOG_JSON=false

# API
OPENAI_API_KEY=

# Paths
DATA_DIR=data
CORPUS_DIR=docs
INDEX_DIR=data/indexes
PROMPT_DIR=prompts

# Chunking (demo tuning)
CHUNK_MODE=preset
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# Retrieval (demo tuning)
RETRIEVAL_MODE=preset
RETRIEVAL_TOP_K=8

# Embeddings
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16
EMBEDDING_NORMALIZE=true
EMBEDDING_HASH_DIMENSION=64

# Reranker
RERANKER_PROVIDER=cross_encoder
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu
RERANKER_BATCH_SIZE=8
RERANKER_TOP_N=6
RERANK_CASCADE_ENABLED=true
RERANK_SIMPLE_SKIP_CROSS_ENCODER=true
RERANK_MIN_CANDIDATES_FOR_CROSS_ENCODER=4
RERANK_SCORE_GAP_THRESHOLD=0.2

# OCR (optional for scanned/image-based PDFs)
OCR_ENABLED=true
OCR_LANGUAGE=vie+eng
OCR_MIN_TEXT_CHARS=100
OCR_RENDER_DPI=216
TESSERACT_CMD=
OCR_CONFIDENCE_THRESHOLD=40

# Workflow limits
MAX_ADVANCED_LOOPS=1
ADVANCED_ADAPTIVE_ENABLED=true
ADVANCED_FORCE_LLM_GATE=false
ADVANCED_FORCE_LLM_CRITIC=false
MEMORY_WINDOW=3

# Caching (LRU for repeated queries)
CACHE_ENABLED=true
EMBEDDING_CACHE_ENABLED=true
RETRIEVAL_CACHE_ENABLED=true
LLM_CACHE_ENABLED=true
RERANK_CACHE_ENABLED=true
CACHE_EMBEDDING_MAXSIZE=256
CACHE_RETRIEVAL_MAXSIZE=128
CACHE_LLM_MAXSIZE=64
CACHE_RERANK_MAXSIZE=128

# Grounding (optional semantic boost over overlap heuristic)
GROUNDING_SEMANTIC_ENABLED=true
GROUNDING_POLICY=adaptive
GROUNDING_SEMANTIC_STANDARD_ENABLED=false
GROUNDING_SEMANTIC_ADVANCED_ENABLED=true
GROUNDING_CACHE_ENABLED=true
GROUNDING_CACHE_MAX_SIZE=512
GROUNDING_SEMANTIC_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
GROUNDING_SEMANTIC_DEVICE=cpu
GROUNDING_SEMANTIC_LOCAL_FILES_ONLY=false
GROUNDING_SEMANTIC_MAX_CONTEXT_CHUNKS=6
GROUNDING_SEMANTIC_MIN_SIMILARITY=0.58
GROUNDING_SEMANTIC_WEIGHT=0.35

# LLM (OpenAI-compatible; Qwen defaults for Ollama)
LLM_PROVIDER=openai_compatible
LLM_MODEL=qwen2.5:3b
LLM_API_BASE=http://172.25.80.1:11434/v1
LLM_API_KEY=ollama
# vLLM alternative:  http://localhost:8000/v1
# SGLang alternative: http://localhost:30000/v1

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=120
LLM_GATE_MAX_TOKENS=128
LLM_REWRITE_MAX_TOKENS=256
LLM_CRITIQUE_MAX_TOKENS=384

# Dynamic query budget for Standard mode
RAG_DYNAMIC_BUDGET_ENABLED=true
RAG_SIMPLE_MAX_TOKENS=384
RAG_NORMAL_MAX_TOKENS=768
RAG_COMPLEX_MAX_TOKENS=1536
RAG_SIMPLE_CONTEXT_CHARS=1600
RAG_NORMAL_CONTEXT_CHARS=3000
