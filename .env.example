# Runtime
ENVIRONMENT=dev
LOG_LEVEL=INFO
LOG_JSON=false

# API
OPENAI_API_KEY=

# Paths
DATA_DIR=data
CORPUS_DIR=docs
INDEX_DIR=data/indexes
PROMPT_DIR=prompts

# Embeddings
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16
EMBEDDING_NORMALIZE=true
EMBEDDING_HASH_DIMENSION=64

# Reranker
RERANKER_PROVIDER=cross_encoder
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu
RERANKER_BATCH_SIZE=8
RERANKER_TOP_N=6

# OCR (optional for scanned/image-based PDFs)
OCR_ENABLED=true
OCR_LANGUAGE=vie+eng
OCR_MIN_TEXT_CHARS=100
OCR_RENDER_DPI=216
TESSERACT_CMD=
OCR_CONFIDENCE_THRESHOLD=40

# Workflow limits
MAX_ADVANCED_LOOPS=2

# LLM (OpenAI-compatible; Qwen defaults for Ollama)
LLM_PROVIDER=openai_compatible
LLM_MODEL=qwen2.5:3b
LLM_API_BASE=http://localhost:11434/v1
LLM_API_KEY=ollama
# vLLM alternative:  http://localhost:8000/v1
# SGLang alternative: http://localhost:30000/v1

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=120
